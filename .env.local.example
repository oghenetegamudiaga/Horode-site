# ─── Supabase ───────────────────────────────────────────
# Get these from your Supabase project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Admin panel ────────────────────────────────────────
# Set this to any strong password you want for the admin login
ADMIN_PASSWORD=your-strong-admin-password-here

# ─── Session secret ─────────────────────────────────────
# Must be at least 32 characters long — any random string
SESSION_SECRET=a-very-long-random-secret-string-at-least-32-chars
